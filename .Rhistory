install.packages("renv")
renv::init()
renv::install(c(
"tidyverse",   # data + plotting
"readxl",      # read .xlsx
"janitor",     # clean tables
"skimr",       # quick QC summaries
"gtsummary",   # clinical-style tables
"ggpubr",      # plot helpers
"sf",          # spatial vectors
"spdep",       # Moran / LISA
"tmap",        # thematic maps (or ggplot2+sf)
"knitr", "gt"  # tables in Quarto
))
library(tidyverse)
library(readxl)
library(janitor)
library(skimr)
